rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwnerByUserId(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /lessons/{docId} {
      allow read: if isOwnerByUserId(resource.data.userId);
      allow create: if isOwnerByUserId(request.resource.data.userId);
      allow update: if isOwnerByUserId(resource.data.userId)
        && isOwnerByUserId(request.resource.data.userId);
      allow delete: if isOwnerByUserId(resource.data.userId);
    }

    match /categories/{docId} {
      allow read: if isOwnerByUserId(resource.data.userId);
      allow create: if isOwnerByUserId(request.resource.data.userId);
      allow update: if isOwnerByUserId(resource.data.userId)
        && isOwnerByUserId(request.resource.data.userId);
      allow delete: if isOwnerByUserId(resource.data.userId);
    }

    match /studyLogs/{docId} {
      allow read: if isOwnerByUserId(resource.data.userId);
      allow create: if isOwnerByUserId(request.resource.data.userId);
      allow update: if isOwnerByUserId(resource.data.userId)
        && isOwnerByUserId(request.resource.data.userId);
      allow delete: if isOwnerByUserId(resource.data.userId);
    }

    match /dictationAttempts/{docId} {
      allow read: if isOwnerByUserId(resource.data.userId);
      allow create: if isOwnerByUserId(request.resource.data.userId);
      allow update: if isOwnerByUserId(resource.data.userId)
        && isOwnerByUserId(request.resource.data.userId);
      allow delete: if isOwnerByUserId(resource.data.userId);
    }

    match /monthlyStats/{docId} {
      allow read: if isOwnerByUserId(resource.data.userId);
      allow create: if isOwnerByUserId(request.resource.data.userId);
      allow update: if isOwnerByUserId(resource.data.userId)
        && isOwnerByUserId(request.resource.data.userId);
      allow delete: if isOwnerByUserId(resource.data.userId);
    }
  }
}
