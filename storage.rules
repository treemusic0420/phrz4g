rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // TEMP: Local data migration exception for UID EpwjD8uFm2YNgqFB8SGPzMB5jfg1.
    // Remove this helper and local-read allow clause after /admin/migrate-local migration is complete.
    function isLocalMigrationUser() {
      return request.auth != null
        && request.auth.uid == 'EpwjD8uFm2YNgqFB8SGPzMB5jfg1';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAllowedImageUpload() {
      return request.resource != null
        && request.resource.size <= 1 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    match /users/{userId}/lesson-audio/{fileName=**} {
      allow read: if isOwner(userId) || (userId == 'local' && isLocalMigrationUser());
      allow write: if isOwner(userId);
    }

    match /users/{userId}/lesson-images/{lessonId}/{fileName=**} {
      allow read: if isOwner(userId) || (userId == 'local' && isLocalMigrationUser());
      allow write: if isOwner(userId)
        && (request.resource == null || isAllowedImageUpload());
    }
  }
}
